NODEXIA_APP_NAME=Nodexia
NODEXIA_ENV=development
NODEXIA_LOG_LEVEL=info
NODEXIA_LOG_FORMAT=text
NODEXIA_HTTP_ADDR=:8080
NODEXIA_HTTP_READ_TIMEOUT=15s
NODEXIA_HTTP_WRITE_TIMEOUT=60s
NODEXIA_HTTP_IDLE_TIMEOUT=30s
NODEXIA_HTTP_SHUTDOWN_TIMEOUT=10s
NODEXIA_SSH_CONNECT_TIMEOUT=10s
NODEXIA_SSH_COMMAND_TIMEOUT=20s

NODEXIA_SESSION_SECRET=nodexia-dev-session-secret-change-me
NODEXIA_AUTH_USERNAME=admin
NODEXIA_AUTH_PASSWORD=change-this-password

NODEXIA_DB_DRIVER=sqlite
NODEXIA_DB_SQLITE_PATH=data/nodexia.sqlite3
NODEXIA_DB_DSN=
NODEXIA_DB_MAX_OPEN_CONNS=10
NODEXIA_DB_MAX_IDLE_CONNS=5
NODEXIA_DB_CONN_MAX_LIFETIME=5m

NODEXIA_DOMAIN=
NODEXIA_AUTO_TLS=true
NODEXIA_BEHIND_REVERSE_PROXY=false

# Telegram alerting (optional). SECRET: keep this only in the environment â€” it is
# never stored in the database, logged, or rendered. Leave empty to disable
# Telegram sending; the alerts UI then shows a "not configured" notice.
NODEXIA_TELEGRAM_BOT_TOKEN=

# Periodic status digest (optional). A recurring Telegram summary of each
# server's month-to-date traffic, forecast / days-to-limit, and active alerts.
# DISABLED by default so existing deployments never start sending unexpectedly.
# NODEXIA_DIGEST_CHANNEL names a notification channel (case-insensitive) to send
# to; leave empty to send to every enabled channel.
NODEXIA_DIGEST_ENABLED=false
NODEXIA_DIGEST_INTERVAL=24h
NODEXIA_DIGEST_CHANNEL=
