#!/usr/bin/env bash
# Nodexia management CLI — a thin, friendly wrapper around the production Docker
# Compose stack. Installed to /usr/local/bin/nodexia by install.sh.
#
#   nodexia up                Start (or recreate) the stack in the background
#   nodexia down              Stop and remove the stack containers
#   nodexia restart [svc]     Restart the stack (or a single service)
#   nodexia logs [svc]        Follow logs (optionally for one service)
#   nodexia status            Show container status
#   nodexia update [args...]  Upgrade to the latest release and redeploy,
#                             preserving secrets. Pin a version instead with
#                             --image-version <tag> (e.g. v0.2.0).
#   nodexia uninstall [opts]  Remove the service, containers and CLI. Keeps the
#                             data volumes and install directory unless --purge.
#                             Options: --purge (also delete data + install dir),
#                             -y/--yes (skip the confirmation prompt)
#
# The install directory defaults to /opt/nodexia and can be overridden with the
# NODEXIA_DIR environment variable or /etc/default/nodexia (written by install.sh
# for non-default install paths).
set -euo pipefail

# shellcheck disable=SC1091
[ -f /etc/default/nodexia ] && . /etc/default/nodexia

NODEXIA_DIR="${NODEXIA_DIR:-/opt/nodexia}"
COMPOSE_FILE="compose.production.yml"
INSTALLER="${NODEXIA_DIR}/scripts/install.sh"
SYSTEMD_UNIT="nodexia.service"
CLI_PATH="/usr/local/bin/nodexia"
CLI_DEFAULTS="/etc/default/nodexia"

# Compose against the production stack needs root (or docker-group) access; for a
# predictable experience re-exec under sudo when not already root.
if [ "${EUID:-$(id -u)}" -ne 0 ]; then
  if command -v sudo >/dev/null 2>&1; then
    exec sudo -E "$0" "$@"
  fi
  echo "nodexia: run as root or with sudo." >&2
  exit 1
fi

# usage prints the leading comment block (after the shebang) up to the first
# non-comment line, so it stays in sync without hard-coded line numbers.
usage() {
  awk 'NR>1 && /^#/ {sub(/^# ?/, ""); print; next} NR>1 {exit}' "$0"
}

die() {
  echo "nodexia: $*" >&2
  exit 1
}

require_stack() {
  [ -f "${NODEXIA_DIR}/${COMPOSE_FILE}" ] ||
    die "stack not found at ${NODEXIA_DIR}. Set NODEXIA_DIR or run install.sh first."
  cd "$NODEXIA_DIR"
}

dc() {
  docker compose -f "$COMPOSE_FILE" "$@"
}

cmd_update() {
  [ -f "$INSTALLER" ] || die "installer not found at ${INSTALLER}."
  # `update` means "get the newest release" by default — otherwise the installer
  # keeps the version pinned in .env.production and nothing actually upgrades.
  # Pass --image-version <tag> to pin a specific release instead.
  local has_version=0 arg
  for arg in "$@"; do
    case "$arg" in
    --image-version | --image-version=*) has_version=1 ;;
    esac
  done
  if [ "$has_version" -eq 0 ]; then
    set -- "$@" --image-version latest
  fi
  exec bash "$INSTALLER" --non-interactive --skip-dns-check --skip-port-check "$@"
}

cmd_uninstall() {
  local purge=0 assume_yes=0 arg reply
  for arg in "$@"; do
    case "$arg" in
    --purge | --remove-data) purge=1 ;;
    -y | --yes) assume_yes=1 ;;
    *) die "uninstall: unknown option '${arg}'" ;;
    esac
  done

  echo "This removes the Nodexia systemd service, containers and the nodexia CLI."
  if [ "$purge" -eq 1 ]; then
    echo "PURGE: the install directory (${NODEXIA_DIR}), the built image and the"
    echo "       data volumes (database + TLS certificates) will be DELETED."
  else
    echo "The install directory and data volumes are kept (rerun the installer to"
    echo "restore). Pass --purge to also delete data and ${NODEXIA_DIR}."
  fi

  if [ "$assume_yes" -ne 1 ]; then
    printf "Continue? [y/N] "
    read -r reply
    case "$reply" in
    y | Y | yes | YES) ;;
    *)
      echo "Aborted."
      exit 0
      ;;
    esac
  fi

  # Stop and disable the systemd service.
  if systemctl list-unit-files 2>/dev/null | grep -q "^${SYSTEMD_UNIT}"; then
    systemctl disable --now "$SYSTEMD_UNIT" >/dev/null 2>&1 || true
  fi

  # Stop and remove the containers (and volumes/image when purging).
  if [ -f "${NODEXIA_DIR}/${COMPOSE_FILE}" ]; then
    if [ "$purge" -eq 1 ]; then
      (cd "$NODEXIA_DIR" && dc down -v --rmi local --remove-orphans) || true
    else
      (cd "$NODEXIA_DIR" && dc down --remove-orphans) || true
    fi
  fi

  # Remove the systemd unit file.
  rm -f "/etc/systemd/system/${SYSTEMD_UNIT}"
  systemctl daemon-reload >/dev/null 2>&1 || true

  # Remove the install directory when purging.
  if [ "$purge" -eq 1 ]; then
    rm -rf "$NODEXIA_DIR"
  fi

  # Remove the CLI defaults and the CLI itself last (safe: the running file is
  # unlinked but stays valid until this process exits).
  rm -f "$CLI_DEFAULTS"
  rm -f "$CLI_PATH"

  echo "Nodexia uninstalled."
  if [ "$purge" -eq 0 ]; then
    echo "Kept: data volumes (nodexia_data, caddy_data) and ${NODEXIA_DIR}."
  fi
}

cmd="${1:-help}"
[ "$#" -gt 0 ] && shift || true

case "$cmd" in
up)
  require_stack
  dc up -d --remove-orphans "$@"
  ;;
down)
  require_stack
  dc down "$@"
  ;;
restart)
  require_stack
  dc restart "$@"
  ;;
logs)
  require_stack
  dc logs -f --tail=200 "$@"
  ;;
status | ps)
  require_stack
  dc ps "$@"
  ;;
update)
  cmd_update "$@"
  ;;
uninstall)
  cmd_uninstall "$@"
  ;;
help | -h | --help)
  usage
  ;;
*)
  echo "nodexia: unknown command '${cmd}'" >&2
  echo >&2
  usage >&2
  exit 1
  ;;
esac
