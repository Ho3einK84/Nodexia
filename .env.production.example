NODEXIA_IMAGE_VERSION=v0.2.2

NODEXIA_APP_NAME=Nodexia
NODEXIA_ENV=production
NODEXIA_LOG_LEVEL=info
NODEXIA_LOG_FORMAT=json
NODEXIA_HTTP_ADDR=:8080
NODEXIA_HTTP_READ_TIMEOUT=15s
NODEXIA_HTTP_WRITE_TIMEOUT=60s
NODEXIA_HTTP_IDLE_TIMEOUT=30s
NODEXIA_HTTP_SHUTDOWN_TIMEOUT=15s

NODEXIA_DB_DRIVER=sqlite
NODEXIA_DB_SQLITE_PATH=/var/lib/nodexia/nodexia.sqlite3
NODEXIA_DB_DSN=
NODEXIA_DB_MAX_OPEN_CONNS=10
NODEXIA_DB_MAX_IDLE_CONNS=5
NODEXIA_DB_CONN_MAX_LIFETIME=5m

NODEXIA_SSH_CONNECT_TIMEOUT=10s
NODEXIA_SSH_COMMAND_TIMEOUT=20s

NODEXIA_SCHEDULER_ENABLED=true
NODEXIA_SCHEDULER_STARTUP_DELAY=15s
NODEXIA_SCHEDULER_SWEEP_INTERVAL=1m
NODEXIA_SCHEDULER_MONITORING_INTERVAL=15m
NODEXIA_SCHEDULER_NODES_INTERVAL=30m
NODEXIA_SCHEDULER_RETRY_BACKOFF=3m
NODEXIA_SCHEDULER_CONNECT_TIMEOUT=10s
NODEXIA_SCHEDULER_COMMAND_TIMEOUT=45s

NODEXIA_SESSION_COOKIE_NAME=nodexia_session
# Required in production: at least 16 characters and must not be the development
# default. Generate a unique random value, e.g. `openssl rand -base64 48`.
NODEXIA_SESSION_SECRET=change-this-production-secret
NODEXIA_SESSION_TTL=12h
NODEXIA_SESSION_COOKIE_SECURE=true
NODEXIA_SSH_HOST_KEY_POLICY=tofu
NODEXIA_SSH_KNOWN_HOSTS_PATH=/var/lib/nodexia/ssh_known_hosts.json

# Both are required in production and must be non-empty. Repeated failed logins
# from the same client are rate limited with an exponential lockout.
NODEXIA_AUTH_USERNAME=admin
NODEXIA_AUTH_PASSWORD=change-this-password

# Telegram alerting (optional, SECRET). Provide a bot token from @BotFather to
# enable alert delivery, then configure rules and channels in the panel under
# /alerts. Leave blank to keep sending disabled.
NODEXIA_TELEGRAM_BOT_TOKEN=

# Periodic status digest (optional). A recurring Telegram summary of each
# server's month-to-date traffic, forecast / days-to-limit, and active alerts.
# DISABLED by default so existing deployments never start sending unexpectedly;
# it requires a configured bot token. NODEXIA_DIGEST_CHANNEL names a notification
# channel (case-insensitive) to send to; leave empty to send to every enabled
# channel.
NODEXIA_DIGEST_ENABLED=false
NODEXIA_DIGEST_INTERVAL=24h
NODEXIA_DIGEST_CHANNEL=

NODEXIA_DOMAIN=panel.example.com
NODEXIA_AUTO_TLS=false
NODEXIA_BEHIND_REVERSE_PROXY=true

NODEXIA_HEALTHCHECK_URL=http://127.0.0.1:8080/healthz
NODEXIA_HEALTHCHECK_TIMEOUT=3s
